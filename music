def play_music(file_path):
    if sys.platform.startswith('win'):
        import winsound
        winsound.PlaySound(file_path, winsound.SND_FILENAME)
    elif sys.platform.startswith('darwin'):
        os.system(f'afplay "{file_path}"')
    else:
        os.system(f'mpg123 "{file_path}"')
    

